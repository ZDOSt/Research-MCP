# Application image. Exact tags are deliberate; update them explicitly.
PYTHON_IMAGE=python:3.11.15-slim-bookworm
RESEARCH_MCP_IMAGE=research-mcp:local
REDIS_IMAGE=redis:7.4.9-alpine3.21
QDRANT_IMAGE=qdrant/qdrant:v1.18.2-unprivileged
SEARXNG_IMAGE=searxng/searxng:2026.7.11-62a1ab7ed
CRAWL4AI_IMAGE=unclecode/crawl4ai:0.9.1
CRAWL4AI_DERIVED_IMAGE=research-crawl4ai:local
RERANKER_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.9.3

# Separate credential for the optional Crawl4AI API. Its upstream image binds
# only to loopback without a token, which makes it unreachable from web-runner.
CRAWL4AI_API_TOKEN=replace-with-at-least-32-random-characters
CRAWL4AI_EGRESS_CONNECT_TIMEOUT_SECONDS=30

# Numeric identity used by both application containers and their writable
# tmpfs mounts. Keep these values aligned.
APP_UID=10001
APP_GID=10001

# The gateway is loopback-only by default. Set MCP_AUTH_TOKEN and terminate TLS
# in a reverse proxy before changing this to 0.0.0.0 on a shared host.
MCP_BIND_ADDRESS=127.0.0.1
MCP_PUBLISHED_PORT=8001
MCP_TRANSPORT=streamable-http
MCP_PATH=/mcp
FASTMCP_CHECK_FOR_UPDATES=off
# Strict DNS-rebinding protection. Add the public reverse-proxy hostname before
# using a remote URL. Origins may stay empty for non-browser MCP clients.
MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,[::1]:*,mcp-gateway:*
MCP_ALLOWED_ORIGINS=
# Optional bearer token. Set this before publishing beyond localhost and send it
# as the MCP client's Authorization: Bearer header.
MCP_AUTH_TOKEN=
# Optional identity for the legacy single-token policy.
MCP_AUTH_CLIENT_ID=research-mcp-client
# Multi-client policies replace MCP_AUTH_TOKEN when non-empty. Keep JSON on one
# line; see README.md for scopes and an example.
MCP_AUTH_TOKENS_JSON=
MCP_ALLOWED_NAMESPACES=*
MCP_ALLOW_LEGACY_UNOWNED_JOBS=false
MCP_ALLOW_UNAUTHENTICATED_REMOTE=false
MCP_MAX_QUERY_CHARS=8000
MCP_MAX_INGEST_CHARS=500000
# Return a durable job ID after this window; the worker continues at full depth.
MCP_SYNC_JOB_WAIT_SECONDS=60
# Internal Redis polling cadence and bounded client-facing long poll. These are
# not instructions for an MCP model to poll repeatedly in one assistant turn.
MCP_JOB_POLL_SECONDS=0.5
MCP_JOB_LONG_POLL_SECONDS=15

# Optional container-to-container client connectivity. These values are used
# only with docker-compose.client-network.yml. The external network must already
# exist and must also contain the LibreChat, OpenWebUI, or other MCP client.
MCP_CLIENT_NETWORK=
MCP_CLIENT_ALIAS=research-mcp
# Uncomment both lines when enabling the client-network override. This makes
# every later Docker Compose command retain the override on every host OS.
# COMPOSE_FILE=docker-compose.yml:docker-compose.client-network.yml
# COMPOSE_PATH_SEPARATOR=:

# Queue and durable job artifacts.
RESEARCH_QUEUE=research:jobs
RESEARCH_SOURCE_CONCURRENCY=2
JOB_RESULT_TTL_SECONDS=2592000
JOB_POLL_INTERVAL_SECONDS=0.5
JOB_MAX_PAYLOAD_BYTES=1048576
JOB_MAX_QUEUED=1000
JOB_MAX_ATTEMPTS=3
JOB_STALE_AFTER_SECONDS=300
JOB_STALE_RECOVERY_INTERVAL_SECONDS=30
# Ingesting jobs fail closed unless Redis confirms that their compensation
# record reached the local AOF within this timeout. Zero disables that guarantee.
JOB_INGESTION_WAITAOF_TIMEOUT_MS=5000
WORKER_HEARTBEAT_TTL_SECONDS=60
ARTIFACT_RETENTION_SECONDS=2592000
ARTIFACT_CLEANUP_INTERVAL_SECONDS=3600
DEFAULT_RESEARCH_NAMESPACE=default
# IANA timezone used to resolve relative dates in retrieval results. This is a
# deployment-wide default; use the timezone of the primary user or audience.
RESEARCH_TIMEZONE=UTC
LOG_LEVEL=INFO

# Vector memory. VECTOR_SIZE must match EMBEDDING_MODEL.
QDRANT_COLLECTION=research_mcp
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_SIZE=384
CHUNK_SIZE=1100
CHUNK_OVERLAP=150
QDRANT_INIT_RETRIES=30
QDRANT_INIT_DELAY_SECONDS=2
QDRANT_HISTORY_RETENTION_SECONDS=2592000
QDRANT_LIFECYCLE_REPAIR_INTERVAL_SECONDS=3600
QDRANT_LIFECYCLE_REPAIR_MAX_POINTS=100000
QDRANT_LOG_LEVEL=INFO

# Optional backend URLs. The defaults address the profile-gated Compose
# services; connection failure degrades to the built-in fallbacks.
CRAWL4AI_URL=http://crawl4ai:11235
RERANKER_URL=http://reranker:8000
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_MAX_RESPONSE_BYTES=2097152
RERANKER_TIMEOUT_SECONDS=20
RERANKER_TOTAL_TIMEOUT_SECONDS=30
SEARXNG_MAX_RESPONSE_BYTES=4194304
SEARXNG_TIMEOUT_SECONDS=30

# Hard response and total-time limits for untrusted web content. The
# CRAWL4AI_NETWORK_ISOLATED assertion is valid for the supplied secure Compose
# topology; do not set it for a Crawl4AI service that can reach private hosts.
DIRECT_MAX_RESPONSE_BYTES=16777216
DIRECT_TOTAL_TIMEOUT_SECONDS=75
DIRECT_EXTRACTION_TIMEOUT_SECONDS=20
# Give safe direct extraction a short head start. Content below the quality gate
# still escalates to Crawl4AI and browser fallbacks.
DIRECT_FIRST_HEDGE_SECONDS=1.5
DIRECT_FIRST_MIN_CONTENT_CHARS=2000
CRAWL4AI_MAX_RESPONSE_BYTES=8388608
CRAWL4AI_TOTAL_TIMEOUT_SECONDS=180
CRAWL4AI_NETWORK_ISOLATED=true
PDF_MAX_RESPONSE_BYTES=8388608
PDF_MAX_PAGES=200
PDF_MAX_EXTRACTED_CHARS=1000000
PDF_SANDBOX_MEMORY_BYTES=536870912
PDF_SANDBOX_CPU_SECONDS=15
PDF_SANDBOX_OUTPUT_BYTES=6065536

# Optional GitHub access. A token enables private repositories and higher rate
# limits. Leave it empty for public, unauthenticated requests.
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
GITHUB_MAX_FILE_CHARS=250000
GITHUB_MAX_RESPONSE_BYTES=8388608
GITHUB_TIMEOUT_SECONDS=45
# Required when GITHUB_TOKEN is set. Prefer explicit owner/repository entries;
# exact * permits repository-less global search.
GITHUB_ALLOWED_REPOSITORIES=
GITHUB_ALLOW_INSECURE_HTTP=false
GITHUB_REDACT_SECRETS=true

# Optional OpenAI-compatible planner/synthesis endpoint. Synthesis is disabled
# until both the endpoint/model are configured and this flag is true.
PLANNER_BASE_URL=
PLANNER_MODEL=
PLANNER_API_KEY=
PLANNER_TIMEOUT_SECONDS=90
PLANNER_MAX_RESPONSE_BYTES=1048576
PLANNER_ALLOW_INSECURE_HTTP=false
PLANNER_ENABLE_SYNTHESIS=false

# Keep Chromium's sandbox and TLS verification enabled. These are emergency
# compatibility switches, not normal deployment settings.
RESEARCH_BROWSER_DISABLE_SANDBOX=false
RESEARCH_BROWSER_IGNORE_HTTPS_ERRORS=false
RESEARCH_BROWSER_TOTAL_TIMEOUT_SECONDS=90
# auto first attempts Chromium's native sandbox, then uses the hardened
# web-runner container as the compatibility sandbox only for a recognized host
# user-namespace denial. Use required with a host policy that permits userns.
RESEARCH_BROWSER_SANDBOX_MODE=auto
WEB_RUNNER_MAX_REQUEST_BYTES=2097152
WEB_RUNNER_MAX_RESPONSE_BYTES=8388608

# Optional split RAG service. The default Compose deployment accesses Qdrant
# directly and leaves USE_RESEARCH_API_RAG=false.
USE_RESEARCH_API_RAG=false
RESEARCH_API_URL=
RESEARCH_API_TOKEN=
RESEARCH_API_ALLOW_INSECURE_HTTP=false
RESEARCH_API_MAX_REQUEST_BYTES=4194304
RESEARCH_API_MAX_RESPONSE_BYTES=8388608
RESEARCH_API_TOTAL_TIMEOUT_SECONDS=180
RESEARCH_API_ALLOW_UNAUTHENTICATED=false
RAG_MAX_INGEST_CHARS=1000000
RAG_MAX_METADATA_BYTES=262144

# Public-web egress broker used by the isolated browser runner.
SAFE_EGRESS_ALLOWED_PORTS=80,443,8080,8443
SAFE_EGRESS_DNS_TIMEOUT_SECONDS=5
SAFE_EGRESS_CONNECT_TIMEOUT_SECONDS=15
SAFE_EGRESS_HANDSHAKE_TIMEOUT_SECONDS=5
SAFE_EGRESS_IDLE_TIMEOUT_SECONDS=45
SAFE_EGRESS_MAX_CONNECTION_SECONDS=120
SAFE_EGRESS_MAX_CONNECTIONS=128
SAFE_EGRESS_QUEUE_TIMEOUT_SECONDS=1
SAFE_EGRESS_MAX_BYTES_PER_DIRECTION=67108864
SAFE_EGRESS_DENY_CIDRS=

# Replace this before any non-local deployment. A random 32-byte hex value is
# suitable, for example: openssl rand -hex 32
SEARXNG_SECRET=replace-with-at-least-32-random-characters

# Resource and log bounds. Increase worker/browser limits for deep research.
GATEWAY_CPUS=1.0
GATEWAY_MEMORY_LIMIT=2g
GATEWAY_PIDS_LIMIT=256
WORKER_CPUS=2.0
WORKER_MEMORY_LIMIT=4g
WORKER_PIDS_LIMIT=512
WORKER_SHM_SIZE=1gb
REDIS_CPUS=0.5
REDIS_MEMORY_LIMIT=512m
REDIS_MAXMEMORY=384mb
QDRANT_CPUS=1.0
QDRANT_MEMORY_LIMIT=2g
SEARXNG_CPUS=1.0
SEARXNG_MEMORY_LIMIT=1g
SEARXNG_WORKERS=2
SEARXNG_THREADS=4
CRAWL4AI_CPUS=2.0
CRAWL4AI_MEMORY_LIMIT=4g
CRAWL4AI_SHM_SIZE=1gb
RERANKER_CPUS=2.0
RERANKER_MEMORY_LIMIT=4g
PDF_RUNNER_CPUS=1.0
PDF_RUNNER_MEMORY_LIMIT=768m
PDF_RUNNER_PIDS_LIMIT=128
SAFE_EGRESS_CPUS=0.5
SAFE_EGRESS_MEMORY_LIMIT=256m
WEB_RUNNER_CPUS=2.0
WEB_RUNNER_MEMORY_LIMIT=4g
WEB_RUNNER_PIDS_LIMIT=512
WEB_RUNNER_SHM_SIZE=1gb
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
